DirectoryIndex index.html

Options -Indexes
ServerSignature Off

<IfModule mod_rewrite.c>
  RewriteEngine On

  RewriteCond %{HTTPS} !=on
  RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [R=301,L]

  RewriteCond %{THE_REQUEST} \s/+index\.html[\s?] [NC]
  RewriteRule ^index\.html$ / [R=301,L]

  RewriteRule ^(wp-admin|wp-includes|wp-content)(/.*)?$ - [G,L,NC]
  RewriteRule ^(wp-login\.php|xmlrpc\.php|wp-config\.php)$ - [G,L,NC]

  RewriteRule ^about-us/?$ /about/ [R=301,L,NC]
  RewriteRule ^projects/?$ /portfolio/ [R=301,L,NC]
  RewriteRule ^portfolio-category/.*$ /portfolio/ [R=301,L,NC]
  RewriteRule ^category/.*$ /blog/ [R=301,L,NC]
  RewriteRule ^tag/.*$ /blog/ [R=301,L,NC]
  RewriteRule ^author/.*$ /about/ [R=301,L,NC]
</IfModule>

<FilesMatch "(^\.|\.env|\.git|\.gitignore|\.gitattributes|composer\.(json|lock)|package(-lock)?\.json|pnpm-lock\.yaml|yarn\.lock|tsconfig\.json|tailwind\.config\.(js|ts)|postcss\.config\.(js|mjs)|next\.config\.(js|mjs)|README|readme|config\.php|phpunit\.xml|\.sql|\.bak|\.backup|\.old|\.log)$">
  Require all denied
</FilesMatch>

<IfModule mod_headers.c>
  Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload" "expr=%{HTTPS} == 'on'"
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set X-Content-Type-Options "nosniff"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  Header always set Permissions-Policy "camera=(), microphone=(), geolocation=(self), payment=(), usb=(), interest-cohort=()"
  Header always set Content-Security-Policy "default-src 'self'; base-uri 'self'; object-src 'none'; frame-ancestors 'self'; form-action 'self' https://formsubmit.co; connect-src 'self' https://formsubmit.co; img-src 'self' data: blob: https:; font-src 'self' data:; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; upgrade-insecure-requests"
  Header unset X-Powered-By

  <FilesMatch "\.(html|htm)$">
    Header set Cache-Control "public, max-age=0, must-revalidate"
  </FilesMatch>

  <FilesMatch "\.(css|js|mjs|woff2?|ttf|otf|eot|svg|png|jpe?g|gif|webp|avif|ico|pdf)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
</IfModule>

<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript application/javascript application/json application/xml image/svg+xml
</IfModule>

<IfModule mod_brotli.c>
  AddOutputFilterByType BROTLI_COMPRESS text/html text/plain text/xml text/css text/javascript application/javascript application/json application/xml image/svg+xml
</IfModule>

<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/html "access plus 0 seconds"
  ExpiresByType text/css "access plus 1 year"
  ExpiresByType application/javascript "access plus 1 year"
  ExpiresByType image/avif "access plus 1 year"
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
  ExpiresByType font/woff2 "access plus 1 year"
</IfModule>
